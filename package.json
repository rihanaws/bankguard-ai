{
  "name": "bankguard-ai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.2.0",
  "scripts": {
    "dev": "bun --bun next dev",
    "build": "bun --bun next build",
    "start": "bun --bun next start",
    "typecheck": "bun x tsc --noEmit",
    "lint:tokens": "bash scripts/check-no-raw-hex.sh",
    "db:generate": "bun x prisma generate",
    "db:migrate": "bun x prisma migrate dev",
    "db:push": "bun x prisma db push",
    "db:validate": "bun x prisma validate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.70.0",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.7",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "prisma": "^7.0.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.8.0"
  }
}
