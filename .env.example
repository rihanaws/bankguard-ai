# PostgreSQL 16 + pgvector. Connection URL is consumed by prisma.config.ts
# (Prisma 7 — the URL never lives in schema.prisma).
DATABASE_URL="postgresql://bankguard:bankguard@localhost:5432/bankguard?schema=public"

# Anthropic API — pipeline stages 1–3
ANTHROPIC_API_KEY=""

# Embedding dimension must stay in sync with KbChunk.embedding vector(1024)
EMBED_DIM="1024"

# Worker lease timeout. RUNNING jobs older than this are eligible for reclaim.
PIPELINE_JOB_LEASE_MS="300000"
